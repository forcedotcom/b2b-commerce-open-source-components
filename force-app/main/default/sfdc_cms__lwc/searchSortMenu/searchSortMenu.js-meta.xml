<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <masterLabel>Sort Menu</masterLabel>
  <description>Displays the search sort menu.</description>
  <apiVersion>66</apiVersion>
  <isExposed>true</isExposed>
  <capabilities>
    <capability>lightning__ServerRenderableWithHydration</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property name="sortRules" type="String" default="{!Search.SortRules.rules}" label="Sort Rules"></property>
      <property name="sortRuleId" type="String" default="{!Search.SortRules.currentSortRuleId}" label="Current Sort Rule"></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="sortRules" cbVisibleIf="false"></designLayoutProperty>
            <designLayoutProperty name="sortRuleId" cbVisibleIf="false"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>