<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <description>Displays tiered discount information</description>
  <apiVersion>64</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Tiered Discounts</masterLabel>
  <capabilities>
    <capability>lightning__ServerRenderableWithHydration</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property label="Quantity Row Label" name="quantityRowLabel" type="String" translatable="true" default="Quantity"></property>
      <property label="Discount Row Label" name="discountRowLabel" type="String" translatable="true" default="Discount per Unit"></property>
      <property label="Tier Border Radius (0px - 100px)" name="borderRadius" type="IntegerSlider" min="0" max="100" default="4"></property>
      <property label="Tier Background Color" name="backgroundColor" type="Color" default="#F7F9FA"></property>
      <property label="Tier Row Title Text Color" name="rowTitleTextColor" type="Color"></property>
      <property label="Tier Column Title Text Color" name="labelTextColor" type="Color"></property>
      <property label="Tier Price Text Color" name="textColor" type="Color"></property>
      <property label="Product Pricing Data Binding" name="productPricing" type="String" default="{!Product.Pricing}"></property>
      <property label="Product Data Binding" name="product" type="String" default="{!Product.Details}"></property>
      <property label="Product Variant Selection Data Binding" name="productVariant" type="String" default="{!Product.SelectedVariant}"></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="quantityRowLabel"></designLayoutProperty>
            <designLayoutProperty name="discountRowLabel"></designLayoutProperty>
            <designLayoutProperty name="borderRadius"></designLayoutProperty>
            <designLayoutProperty name="backgroundColor"></designLayoutProperty>
            <designLayoutProperty name="rowTitleTextColor"></designLayoutProperty>
            <designLayoutProperty name="labelTextColor"></designLayoutProperty>
            <designLayoutProperty name="textColor"></designLayoutProperty>
            <designLayoutProperty name="productPricing"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>