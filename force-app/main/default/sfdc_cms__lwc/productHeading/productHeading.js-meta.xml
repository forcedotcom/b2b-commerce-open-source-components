<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>64</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Product Detail Headings</masterLabel>
  <description>Display the product summary.</description>
  <capabilities>
    <capability>lightning__ServerRenderableWithHydration</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property label="SKU Field Label" name="identifierName" type="String" default="SKU#" translatable="true"></property>
      <property label="Fields" name="productDetailSummaryFieldMapping" type="ProductFieldMapping" default="[]" translatable="true" description="Select the fields to show with each product."></property>
      <property label="Show Additional Fields" name="showAdditionalFields" type="boolean" default="false"></property>
      <property label="Dynamic Attributes Text" name="dynamicAttributesAvailableText" type="String" default="{0} Configurable Attributes" translatable="true"></property>
      <property label="Product Data Binding" name="product" type="String" default="{!Product.Details}"></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="identifierName"></designLayoutProperty>
            <designLayoutProperty name="productDetailSummaryFieldMapping"></designLayoutProperty>
            <designLayoutProperty name="showAdditionalFields"></designLayoutProperty>
            <designLayoutProperty name="dynamicAttributesAvailableText"></designLayoutProperty>
            <designLayoutProperty name="product"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>