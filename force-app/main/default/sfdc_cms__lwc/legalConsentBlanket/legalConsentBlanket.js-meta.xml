<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>64</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Legal Consent Blanket</masterLabel>
  <description>Displays a blanket consent modal for consenting to tracking cookies.</description>
  <capabilities>
    <capability>lightning__ServerRenderableWithHydration</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property name="acceptButtonText" type="String" default="Accept" translatable="true" label="Accept Button Text" description="Text for the accept button."></property>
      <property name="rejectButtonText" type="String" default="Reject" translatable="true" label="Reject Button Text" description="Text for the reject button."></property>
      <property name="excludedPages" type="String" label="Excluded Pages" description="Comma-separated list of page paths to exclude from the blanket consent modal."></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="excludedPages"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
        <designSection name="Button Styles">
          <designLayoutItems>
            <designLayoutProperty name="acceptButtonText"></designLayoutProperty>
            <designLayoutProperty name="rejectButtonText"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>