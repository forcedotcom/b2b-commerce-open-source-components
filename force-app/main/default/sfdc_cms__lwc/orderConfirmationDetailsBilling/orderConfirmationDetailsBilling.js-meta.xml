<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>64</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Billing Details</masterLabel>
  <description>Shows the billing details of the order.</description>
  <capabilities>
    <capability>lightning__ServerRenderableWithHydration</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property name="billingDetails" label="Billing Details Expression" type="String" default="{!BillingDetails}"></property>
      <property name="ownerInfo" label="Owner Details Expression" type="String" default="{!Order.Owner}"></property>
      <property name="billingAddressLabel" label="Billing Address Label" type="String" default="Billing Address" translatable="true"></property>
      <property name="emailAddressLabel" label="Email Address Label" type="String" default="Email ID" translatable="true"></property>
      <property name="paymentMethodLabel" label="Payment Method Label" type="String" default="Payment Method" translatable="true"></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="billingDetails"></designLayoutProperty>
            <designLayoutProperty name="ownerInfo"></designLayoutProperty>
            <designLayoutProperty name="billingAddressLabel"></designLayoutProperty>
            <designLayoutProperty name="emailAddressLabel"></designLayoutProperty>
            <designLayoutProperty name="paymentMethodLabel"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>