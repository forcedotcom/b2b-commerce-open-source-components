<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>64</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Product Details (Tabular)</masterLabel>
  <description>Add a product table information to your page</description>
  <capabilities>
    <capability>lightning__ServerRenderableWithHydration</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property label="Fields" name="productDetailDataContentMapping" type="ProductFieldMapping" default="[]" translatable="true" description="Select the fields to show with each product."></property>
      <property label="Product Data Binding" name="product" type="String" default="{!Product.Details}"></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="productDetailDataContentMapping"></designLayoutProperty>
            <designLayoutProperty name="product"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>