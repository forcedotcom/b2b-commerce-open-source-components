                                                                    "listType": "unformatted",
                                                                    "showPagination": true,
                                                                    "autoScrollToMostRecent": true
                                                                },
                                                                "children": [
                                                                    {
                                                                        "name": "sfdcRepeaterItem",
                                                                        "title": "Repeater",
                                                                        "type": "region",
                                                                        "children": [
                                                                            {
                                                                                "definition": "commerce_builder:orderLineItem",
                                                                                "type": "component",
                                                                                "attributes": {
                                                                                    "productUnavailableMessage": "",
