{
    "presets": [
        {
            "view": {
                "definition": "site:orderProducts",
                "type": "component",
                "children": [
                    {
                        "name": "orderProductsInfoRepeater",
                        "type": "region",
                        "children": [
                            {
                                "definition": "dxp_content_layout:list",
