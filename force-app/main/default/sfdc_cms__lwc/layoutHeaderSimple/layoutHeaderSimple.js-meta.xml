<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>64</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Header - Simple</masterLabel>
  <description>Simplified page header to keep customers focused on the page.</description>
  <capabilities>
    <capability>lightning__ServerRenderableWithHydration</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property name="headerIconsColor" type="Color" label="Header Icons Color"></property>
      <property name="headerIconsHoverColor" type="Color" label="Header Icons Hover Color"></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="headerIconsColor"></designLayoutProperty>
            <designLayoutProperty name="headerIconsHoverColor"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>