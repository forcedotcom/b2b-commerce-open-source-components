<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <masterLabel>Shipping Method</masterLabel>
  <description>Show shipping options at checkout.</description>
  <apiVersion>65</apiVersion>
  <isExposed>true</isExposed>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property name="checkoutDetails" type="String" default="{!Checkout.Details}" label="Checkout Expression" description="Access checkout data. {!Checkout.Details} is the fixed text for this expression. Do not change or delete."></property>
      <designLayout>
        <designSection name="Binding Expressions">
          <designLayoutItems>
            <designLayoutProperty name="checkoutDetails"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>