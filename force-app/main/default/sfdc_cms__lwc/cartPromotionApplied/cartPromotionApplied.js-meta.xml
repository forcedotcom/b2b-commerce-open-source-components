<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>64</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Applied Promotions</masterLabel>
  <description>Show a list of promotions applied to the cart.</description>
  <capabilities>
    <capability>lightning__ServerRenderableWithHydration</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property name="showDiscountAmount" type="Boolean" default="true" label="Show discount amount"></property>
      <property name="showTermsAndConditions" type="Boolean" default="false" label="Show terms and conditions" description="Terms and conditions are based on the promotion&amp;apos;s settings."></property>
      <property name="termsAndConditionsTitleText" type="String" default="Terms and Conditions" translatable="true" label="Terms and Conditions Header" description="Header for the window that shows terms and conditions for a promotion."></property>
      <property name="name" type="String" default="{!Promotion.name}" label="Promotion Name" description="This expression provides the name that&amp;apos;s shown for an automatic promotion."></property>
      <property name="couponId" type="String" default="{!Promotion.couponId}" label="Coupon ID" description="This expression provides the coupon ID that&amp;apos;s required to show an applied manual promotion."></property>
      <property name="termsAndConditions" type="String" default="{!Promotion.termsAndConditions}" label="Terms and Conditions" description="This expression provides the terms and conditions for an applied promotion."></property>
      <property name="couponCode" type="String" default="{!Promotion.couponCode}" label="Coupon Code" description="This expression provides the coupon code that&amp;apos;s shown for a manual promotion."></property>
      <property name="backgroundColor" type="Color" default="rgba(255, 255, 255, 0)" label="Background Color"></property>
      <property name="appliedPromotionFontSize" type="String" default="medium" label="Text Size" datasource="java://siteforce.customComponent.datasource.SLDSFontSizeDataSource"></property>
      <property name="appliedPromotionTextColor" type="Color" label="Text Color"></property>
      <property name="appliedPromotionBackgroundColor" type="Color" label="Background Color"></property>
      <property name="borderColor" type="Color" label="Border Color"></property>
      <property name="borderRadius" type="IntegerSlider" min="0" max="50" default="8" label="Border Radius (0px - 50px)" description="A value of 0 will follow the regular button theme border radius setting."></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="showDiscountAmount"></designLayoutProperty>
            <designLayoutProperty name="backgroundColor"></designLayoutProperty>
            <designLayoutProperty name="appliedPromotionFontSize"></designLayoutProperty>
            <designLayoutProperty name="appliedPromotionTextColor"></designLayoutProperty>
            <designLayoutProperty name="appliedPromotionBackgroundColor"></designLayoutProperty>
            <designLayoutProperty name="borderColor"></designLayoutProperty>
            <designLayoutProperty name="borderRadius"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
        <designSection name="termsAndConditions">
          <designLayoutItems>
            <designLayoutProperty name="showTermsAndConditions"></designLayoutProperty>
            <designLayoutProperty name="termsAndConditionsTitleText" cbVisibleIf="showTermsAndConditions"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
        <designSection name="promotionExpressions">
          <designLayoutItems>
            <designLayoutProperty name="name"></designLayoutProperty>
            <designLayoutProperty name="couponId"></designLayoutProperty>
            <designLayoutProperty name="termsAndConditions"></designLayoutProperty>
            <designLayoutProperty name="couponCode"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>