                                    "itemSpacing": "small",
                                    "listType": "unformatted",
                                    "showPagination": true,
                                    "autoScrollToMostRecent": true
                                },
                                "children": [
                                    {
                                        "name": "sfdcRepeaterItem",
                                        "title": "Repeater",
                                        "type": "region",
                                        "children": [
                                            {
                                                "definition": "commerce_builder:orderSummary",
                                                "type": "component",
                                                "children": [
                                                    {
                                                        "name": "orderNumberLabel",
                                                        "title": "orderNumberLabel",
                                                        "type": "region",
                                                        "children": [
                                                            {
                                                                "definition": "dxp_base:textBlock",
                                                                "type": "component",
                                                                "attributes": {
