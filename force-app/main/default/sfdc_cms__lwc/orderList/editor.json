{
    "presets": [
        {
            "view": {
                "definition": "site:orderList",
                "type": "component",
                "children": [
                    {
                        "name": "orderListRepeater",
                        "type": "region",
                        "children": [
                            {
                                "definition": "dxp_content_layout:list",
                                "type": "component",
