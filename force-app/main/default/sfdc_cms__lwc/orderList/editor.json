                                                        "children": [
                                                            {
                                                                "definition": "dxp_base:textBlock",
                                                                "type": "component",
                                                                "attributes": {
                                                                    "text": "{!OrderSummary.orderNumber}",
                                                                    "textDisplayInfo": "{\"textStyle\": \"heading-small\"}"
                                                                }
                                                            }
                                                        ]
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                ],
                                "dataProviders": [
                                    {
                                        "definition": "sfdc_cms__commerceOrderListDataProvider",
                                        "type": "dataProvider",
                                        "sfdcExpressionKey": "OrderSummary",
                                        "attributes": {}
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        }
    ]
