<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>66</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Navigation Container</masterLabel>
  <description>Add a container for side or top navigation items, depending on the display device.</description>
  <capabilities>
    <capability>lightning__ServerRenderable</capability>
  </capabilities>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property name="backgroundColor" type="Color" label="Background Color"></property>
      <designLayout>
        <designSection>
          <designLayoutItems>
            <designLayoutProperty name="backgroundColor"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>