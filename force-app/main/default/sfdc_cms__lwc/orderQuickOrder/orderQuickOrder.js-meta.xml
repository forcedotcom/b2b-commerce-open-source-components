<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <masterLabel>Quick Order</masterLabel>
  <description>Show a simple form that lets customers add products to their carts by entering SKUs.</description>
  <apiVersion>64</apiVersion>
  <isExposed>true</isExposed>
  <targets>
    <target>lightningCommunity__Page</target>
    <target>lightningCommunity__Default</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightningCommunity__Page">
      <paletteSection>Open Code</paletteSection>
    </targetConfig>
    <targetConfig targets="lightningCommunity__Default">
      <property name="numberOfLineItemsToStart" type="String" default="5" label="Default Number of Fields" description="Set the number of product fields to show at the start of a quick order."></property>
      <property name="numberOfLineItemsToAddEachTime" type="String" default="3" label="Number of Fields Added" description="Set the number of new product fields created each time a customer adds more."></property>
      <property name="searchInputPlaceHolderText" type="String" default="Enter Sku" translatable="true" label="Enter SKU"></property>
      <property name="skuLabelText" type="String" default="SKU# {0}" translatable="true" label="SKU Label"></property>
      <property name="addEntryButtonText" type="String" default="+ Add Product" translatable="true" label="Link Text"></property>
      <property name="addEntryButtonTextColor" type="Color" label="Link Text Color"></property>
      <property name="addEntryButtonTextHoverColor" type="Color" label="Link Text Hover Color"></property>
      <property name="addToCartButtonText" type="String" default="Add To Cart" translatable="true" label="Button Text"></property>
      <property name="addToCartButtonBackgroundColor" type="Color" label="Button Background Color"></property>
      <property name="addToCartButtonBackgroundHoverColor" type="Color" label="Button Background Hover Color"></property>
      <property name="addToCartButtonBorderColor" type="Color" label="Button Border Color"></property>
      <property name="addToCartButtonBorderRadius" type="Integer" min="0" max="50" default="0" label="Button Border Radius (0px - 50px)"></property>
      <property name="addToCartButtonProcessingText" type="String" default="Adding..." translatable="true" label="Adding..."></property>
      <property name="addToCartButtonTextColor" type="Color" label="Button Text Color"></property>
      <property name="addToCartButtonTextHoverColor" type="Color" label="Button Text Hover Color"></property>
      <property name="minimumValueGuideText" type="String" default="Minimum quantity is {0}" translatable="true" label="Minimum Quantity Text" description="Display text for this rule. The value for {0} populates from product settings. Place {0}, untranslated, anywhere in the text. For example, “Buy {0} to start”. The text is shown on the product and as hover text for the quantity selector’s information icon."></property>
      <property name="maximumValueGuideText" type="String" default="Maximum quantity is {0}" translatable="true" label="Maximum Quantity Text" description="Display text for this rule. The value for {0} populates from product settings. Place {0}, untranslated, anywhere in the text. For example, “Buy up to {0}”. The text is shown on the product and as hover text for the quantity selector’s information icon."></property>
      <property name="incrementValueGuideText" type="String" default="Sold in increments of {0}" translatable="true" label="Increment Quantity Text" description="Display text for this rule. The value for {0} populates from product settings. Place {0}, untranslated, anywhere in the text. For example, “Sold in increments of {0}”. The text is shown on the product and as hover text for the quantity selector’s information icon."></property>
      <designLayout>
        <designSection name="QuickOrder">
          <designLayoutItems>
            <designLayoutProperty name="searchInputPlaceHolderText"></designLayoutProperty>
            <designLayoutProperty name="skuLabelText"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
        <designSection name="Add Product Link">
          <designLayoutItems>
            <designLayoutProperty name="addEntryButtonText"></designLayoutProperty>
            <designLayoutProperty name="addEntryButtonTextColor"></designLayoutProperty>
            <designLayoutProperty name="addEntryButtonTextHoverColor"></designLayoutProperty>
            <designLayoutProperty name="numberOfLineItemsToStart"></designLayoutProperty>
            <designLayoutProperty name="numberOfLineItemsToAddEachTime"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
        <designSection name="Quantity Selector">
          <designLayoutItems>
            <designLayoutProperty name="minimumValueGuideText"></designLayoutProperty>
            <designLayoutProperty name="maximumValueGuideText"></designLayoutProperty>
            <designLayoutProperty name="incrementValueGuideText"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
        <designSection name="Add to Cart Button">
          <designLayoutItems>
            <designLayoutProperty name="addToCartButtonText"></designLayoutProperty>
            <designLayoutProperty name="addToCartButtonProcessingText"></designLayoutProperty>
            <designLayoutProperty name="addToCartButtonTextColor"></designLayoutProperty>
            <designLayoutProperty name="addToCartButtonTextHoverColor"></designLayoutProperty>
            <designLayoutProperty name="addToCartButtonBackgroundColor"></designLayoutProperty>
            <designLayoutProperty name="addToCartButtonBackgroundHoverColor"></designLayoutProperty>
            <designLayoutProperty name="addToCartButtonBorderColor"></designLayoutProperty>
          </designLayoutItems>
        </designSection>
      </designLayout>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>